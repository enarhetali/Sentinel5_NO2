datas_path="../Sentinel5_NO2/datas_sentinel5/archives/"
#Parameter:
remove_Q1=FALSE
quality_check=TRUE
weather=FALSE
quality_threshold=5
NA_APPROX="linear" #Select between "linear", "spline", "stine"
library("imputeTS")
library("dsa")
library("stringr")
library("tidyr")
library("dplyr")
library("ggplot2")
library("reshape2")
library("olsrr")
library("zoo")
ls=list.files(datas_path)
df=data.frame()
if(2==1){
for(elem in ls){
if(str_sub(elem, start=-7) == ".csv.gz"){
df_add=read.csv(paste0(datas_path,elem), sep=",")[ ,-c(1)]
df_add=df_add[(df_add$longitude <= 116.504075) & (df_add$longitude >= 116.251599) & (df_add$latitude >= 39.832149) & (df_add$latitude <= 40.029571),]
df=bind_rows(df_add, df)
}
}
remove(df_add)
df["Date"]=as.Date(paste0(df$year, '-', df$month, '-', df$day_mean))
df=df[,-c(1:3,14:17)]
#write.csv(df, "pekin.csv")
}
df=read.csv("paris_Opti.csv")[,-c(1)]
#summary(df)
#Aggregate by IDF
df["coef"]=df$NO2*df$counter
df_agg=df %>% group_by(Date) %>% summarise(coef = sum(coef), counter=sum(counter))
df_agg["NO2"]=df_agg$coef/df_agg$counter
df_agg$Date=as.Date(df_agg$Date)
#Vérification qualité de la donnée
if(quality_check==TRUE){
df_agg["variation"]=c(0,diff(df_agg$NO2))/df_agg$NO2
df_agg=df_agg[(abs(df_agg$variation) <= abs(quality_threshold)) | (df_agg$NO2 <= 0),-ncol(df_agg)]
}
#Remove Q1
if(remove_Q1){
Q1=as.numeric(quantile(df_agg$counter)[2])
df_agg=df_agg[df_agg$counter >= Q1,]
}
#Weather join - Need WAQI data first
if(weather){
ls_weather=list.files("datas/")
df_weather=data.frame()
for(elem in ls_weather){
if(str_sub(elem, start=-4) == ".csv"){
df_add=read.csv(paste0("datas/",elem), sep=",", skip = 4)
df_add=df_add[df_add$Country=="FR"& df_add$City=="Paris",]
df_weather=bind_rows(df_add, df_weather)
}
}
remove(df_add)
df_weather$Date=as.Date(df_weather$Date)
#Long to wide
df_weather <- dcast(df_weather, Date ~ Specie, median)
#Fix wind columns
df_weather[is.na(df_weather[,"wind-gust"]),"wind-gust"]=df_weather[is.na(df_weather[,"wind-gust"]),"wind gust"]
df_weather[is.na(df_weather[,"wind-speed"]),"wind-speed"]=df_weather[is.na(df_weather[,"wind-speed"]),"wind speed"]
df_weather=df_weather[,!(names(df_weather) %in% c("wind speed","wind gust"))]
df_weather=df_weather[,c("Date","humidity","pressure","temperature","wind-speed","wind-gust")]
df_agg=merge(df_agg, df_weather, by="Date",all.x=T)
model <- lm(NO2 ~ ., data = df_agg[,-c(1)])
test=ols_step_backward_p(model)
test=data.frame(Date=subset(df_agg$Date, !(index(df_agg[,"Date"]) %in% test$model$na.action)), NO2=as.vector(test$model$coefficients[1]+test$model$residuals))
df_agg=merge(df_agg, test, by="Date", all.y=T)
df_agg=df_agg[,c(1:3,ncol(df_agg))]
colnames(df_agg)[ncol(df_agg)]="NO2"
#remove(model, test, df_weather)
}
#Fix limits
if(sum(df_agg$Date <= "2018-12-20") == 0){
df_agg=rbind(data.frame(Date=as.Date("2018-12-20"), coef=df_agg[1,]$coef, counter=df_agg[1,]$counter, NO2=df_agg[1,]$NO2), df_agg)
}
if(sum(df_agg$Date >= "2020-06-30") == 0){
df_agg=rbind(data.frame(Date=as.Date("2020-06-30"), coef=df_agg[1,]$coef, counter=df_agg[nrow(df_agg),]$counter, NO2=df_agg[nrow(df_agg),]$NO2), df_agg)
}
#Fixing empty dates
df_plot=data.frame(Date=seq(min(df_agg$Date), by = "day", length.out = max(df_agg$Date)-min(df_agg$Date)+1))
df_plot=merge(df_plot, df_agg, by="Date", all.x=T)
df_plot=df_plot[,-c(2,3)]
df_plot$NO2=na_interpolation(df_plot$NO2,option=NA_APPROX)
#Rolling average
df_plot["roll_avg"]=rollmean(df_plot$NO2, 21, align="right", na.pad = TRUE)
#Compare yearly
df_2019=df_plot[df_plot$Date >= "2019-01-09" & df_plot$Date <= "2019-06-30",]
df_2020=df_plot[df_plot$Date >= "2020-01-09" & df_plot$Date != "2020-02-29" & df_plot$Date <= "2020-06-30",]
df_2020["roll_avg_2019"]=df_2019$roll_avg
df_2020["roll_diff_year"]=((df_2020$roll_avg-df_2019$roll_avg)/df_2019$roll_avg)*100
#Plot not corrected
My_Theme = theme(
axis.title.y = element_text(size = 8))
ggplot(df_2020, aes(Date, roll_diff_year)) + geom_line() + ggtitle("Nitrogen dioxide pollution not corrected by satellite meteorological data - France") +
xlab("Date") +
ylab("Annual variance of the NO2 pollution index (%, 21-day moving average)") +
scale_x_date(date_breaks = "14 day", date_labels = "%d %b") +
My_Theme
#Cleaning Environment
rm(list = ls()[!(ls() %in% c("df_WAQI","df_2020","My_Theme","NA_APPROX"))])
df=merge(df_WAQI[,c(1,6)], df_2020[,c(1,5)], by="Date", all.x=T)
colnames(df)=c("Date","WAQI","Sentinel5")
